# Sunny fleet collector — CENTRAL host config. Copy to .env (never commit .env).
#   cp .env.example .env
#
# You only need the fleet domain (+ email for Let's Encrypt). The push token is
# auto-generated on first start; worker VPS agents fetch it via GET /api/fleet-config.

# The global/fleet domain (DNS A record → this host).
CENTRAL_DOMAIN=fleet.example.com

# Email for Let's Encrypt / Certbot. Default if omitted: admin@<CENTRAL_DOMAIN>
ACME_EMAIL=admin@example.com

# OPTIONAL — leave blank: a strong token is auto-generated and saved under DATA_DIR.
# In compose that is the collector-data volume mounted at /data/fleet_push.token.
# The direct HTTP fallback uses host ./data/fleet_push.token.
# COLLECTOR_TOKENS=

# Minutes after which a run with no fresh push is flagged "stale" on the board.
STALE_AFTER_MIN=15

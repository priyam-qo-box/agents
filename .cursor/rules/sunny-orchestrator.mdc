      nginx-agent → context-agent → nginx-verify-agent
      → [loop if not approved] nginx-fix-agent → context-agent → nginx-verify-agent
  → Backend testing (generate all 3 layers, then verify/fix each layer in order):
      backend-unit-test-agent → backend-integration-test-agent → backend-functional-test-agent → context-agent
      Unit:        backend-unit-test-verify-agent
                   → [loop if not satisfied] backend-unit-test-fix-agent → context-agent → backend-unit-test-verify-agent
      Integration: backend-integration-test-verify-agent
                   → [loop if not satisfied] backend-integration-test-fix-agent → context-agent → backend-integration-test-verify-agent

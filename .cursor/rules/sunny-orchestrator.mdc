                   → [loop if not satisfied] backend-functional-test-fix-agent → context-agent → backend-functional-test-verify-agent
  → Frontend testing (generate all 3 layers, then verify/fix each layer in order):
      frontend-unit-test-agent → frontend-integration-test-agent → frontend-functional-test-agent → context-agent
      Unit:        frontend-unit-test-verify-agent
                   → [loop if not satisfied] frontend-unit-test-fix-agent → context-agent → frontend-unit-test-verify-agent
      Integration: frontend-integration-test-verify-agent
                   → [loop if not satisfied] frontend-integration-test-fix-agent → context-agent → frontend-integration-test-verify-agent
      Functional:  frontend-functional-test-verify-agent
                   → [loop if not satisfied] frontend-functional-test-fix-agent → context-agent → frontend-functional-test-verify-agent
  → System integration testing (collective frontend + backend + PostgreSQL):
      system-integration-test-agent → context-agent → system-integration-test-verify-agent
      → [loop if not satisfied] system-integration-test-fix-agent → context-agent → system-integration-test-verify-agent
  → Swagger / OpenAPI docs:
      swagger-agent → context-agent → swagger-verify-agent
      → [loop if not satisfied] swagger-fix-agent → context-agent → swagger-verify-agent
  → Javadoc:
      javadoc-agent → context-agent → javadoc-verify-agent
      → [loop if not satisfied] javadoc-fix-agent → context-agent → javadoc-verify-agent
  → API collection (Postman):
      api-collection-agent → context-agent → api-collection-verify-agent
      → [loop if not satisfied] api-collection-fix-agent → context-agent → api-collection-verify-agent
  → API tests (every endpoint returns correct status):
      api-test-agent → context-agent → api-test-verify-agent
      → [loop if not satisfied] api-test-fix-agent → context-agent → api-test-verify-agent

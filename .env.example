# Sunny / JHipster stack — environment template (REFERENCE ONLY)
#
# You normally do NOT create .env by hand. At intake, Maya auto-generates
# everything from the two domains you give Sunny (project + fleet) plus
# optional Certbot email. .env is gitignored.
#
# Copy this only to OVERRIDE values (Maya never clobbers an existing .env —
# she only fills missing keys):  cp .env.example .env  &&  edit as needed.
# `change-me*` below are placeholders the agent replaces with generated secrets.

# ----- Deployment (captured at Sunny intake) ---------------------------------
DOMAIN=example.com
ACME_EMAIL=admin@example.com
# Single host: https://${DOMAIN}/ → frontend, https://${DOMAIN}/api → gateway

# ----- Progress dashboard (early publisher, before Nginx stage) --------------
PROGRESS_PORT=8787
# Early URL: http://<server-ip>:${PROGRESS_PORT}/agentprogress.html
# Final URL: https://${DOMAIN}/agentprogress.html

# ----- Fleet / global dashboard (auto from fleet domain at intake) ------------
# Maya sets these from the fleet domain you give Sunny — do not edit by hand.
# FLEET_DOMAIN=fleet.example.com
# CENTRAL_DASHBOARD_URL=https://fleet.example.com
# CENTRAL_PUSH_TOKEN=   # auto-fetched: GET /api/fleet-config on the fleet host
# RUN_ID=               # auto-generated per VPS at intake

# ----- PostgreSQL (one DB per microservice is typical in JHipster) -----------
POSTGRES_USER=sunny
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_HOST=postgresql
POSTGRES_PORT=5432

# ----- JHipster / Spring (per-service overrides in docker-compose) -----------
SPRING_PROFILES_ACTIVE=prod,api-docs
# JWT secret — generate: openssl rand -base64 64
JHIPSTER_SECURITY_AUTHENTICATION_JWT_BASE64_SECRET=change-me-generate-with-openssl

# ----- Frontend (React) ------------------------------------------------------
# Production API base (set by Naveen at Nginx stage):
VITE_API_URL=https://${DOMAIN}/api
# or for Create React App:
# REACT_APP_API_URL=https://${DOMAIN}/api

# ----- Optional: registry (JHipster microservices) -------------------------
JHIPSTER_REGISTRY_PASSWORD=change-me

# ----- Optional: dashboard Basic-Auth (only if you enable it in Nginx) --------
# DASHBOARD_AUTH_USER=admin
# DASHBOARD_AUTH_PASSWORD=change-me
